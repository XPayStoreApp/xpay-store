{
  "buildCommand": "cd artifacts/xpay-store && pnpm install && pnpm run build",
  "outputDirectory": "artifacts/xpay-store/dist/public",
  "installCommand": "pnpm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
